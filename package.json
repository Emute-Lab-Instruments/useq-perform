  "scripts": {
    "build": "npm run build:assets && vite build",
    "build:assets": "node scripts/build-assets.mjs",
    "build:wasm": "cd src-useq && ./scripts/build_wasm.sh",
    "watch": "npm-run-all --parallel watch:assets watch:vite",
    "watch:assets": "node scripts/build-assets.mjs --watch",
    "watch:vite": "vite build --watch",
    "dev": "npm-run-all --parallel config-server start watch",
    "config-server": "node scripts/config-server.mjs",
    "start": "serve public -p 5000 --cors --config serve.json",
    "test:mocha": "mocha \"test/**/*.mjs\"",
    "test:unit": "vitest run --project unit",
    "test:all": "npm-run-all test:mocha test:unit",
    "test": "npm run test:all",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "resolutions": {
    "@codemirror/state": "latest"
  }
